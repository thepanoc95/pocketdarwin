.PATH: ${.CURDIR}/src
.PATH: ${.OBJDIR}

MK_WERROR = no
MK_OBJC_RUNTIME = no

LIB = dispatch
SRCS =	allocator.c \
	apply.c \
	benchmark.c \
	block.cpp \
	data.c \
	data_objc.m \
	init.c \
	introspection.c \
	io.c \
	mach.c \
	object.c \
	object_objc.m \
	once.c \
	queue.c \
	semaphore.c \
	source.c \
	time.c \
	transform.c \
	voucher.c \
	event/event.c \
	event/event_kevent.c \
	event/workqueue.c \
	shims.c \
	shims/lock.c \
	shims/yield.c \
	firehose/firehose_buffer.c
#	provider.d
#	firehose/firehose_server.c
#	firehose/firehose_server_object.m

# Generated by mig in ${.OBJDIR}
SRCS += libdispatch_internal_protocolServer.c \
	libdispatch_internal_protocolUser.c \
	firehoseServer.c \
	firehoseUser.c \
	firehoseReplyServer.c \
	firehoseReplyUser.c
LOBJS = ${SRCS:S/.cpp$/.o/:S/.m$/.o/:%.c=%.o}

CFLAGS = -fvisibility=hidden -DTARGET_OS_BRIDGE=0 -DHAVE_CONFIG_H -DHAVE_MACH \
	-DUSE_MACH_SEM -DUSE_OBJC -DOS_FIREHOSE_SPI -DDISPATCH_DEBUG \
	-DHAVE_PTHREAD_WORKQUEUE_QOS -DVOUCHER_USE_MACH_VOUCHER -D__BLOCKS__ \
	-DPRIVATE -DDISPATCH_COCOA_COMPAT -DDISPATCH_USE_KEVENT_WORKLOOP \
	--sysroot=${RAVYN_SDKROOT} -w -Wno-elaborated-enum-base \
	-fno-exceptions -fblocks -fdollars-in-identifiers \
	-momit-leaf-frame-pointer -mmacos-version-min=${MACOS_VERSION_MIN} \
	-I${RAVYN_SDKROOT}/usr/local/include/kernel \
	-I${RAVYN_SDKROOT}/System/Library/Frameworks/System.framework/Versions/B/PrivateHeaders \
	-I${.CURDIR}/.. -I${.CURDIR} -I${.CURDIR}/private/dispatch \
	-I${.CURDIR}/../../libsystem_blocks -I${.OBJDIR}/.. -I${.CURDIR}/src \
	-I${.OBJDIR} -I${.CURDIR}/../../libsystem_pthread \
	-I${.CURDIR}/../../libsystem_platform/include \
	-I${ROOT_SOURCE_DIR}/Kernel/xnu/libkern \
	-I${ROOT_SOURCE_DIR}/Kernel/xnu/bsd \
	-I${ROOT_SOURCE_DIR}/Kernel/xnu/libsyscall \
	-I${ROOT_SOURCE_DIR}/Kernel/xnu/libsyscall/wrappers/libproc \
	-I${ROOT_SOURCE_DIR}/Frameworks/Foundation/Headers \
	-I${.CURDIR}/../../private -I${.CURDIR}/../private

MIG_FLAGS = --sysroot=${RAVYN_SDKROOT} -g -DPRIVATE \
	-mmacos-version-min=${MACOS_VERSION_MIN} -D__MigTypeCheck
MIGCC = ${CC}
.export MIGCC

LDFLAGS = -L${RAVYN_SDKROOT}/usr/lib/system -L${RAVYN_SDKROOT}/usr/lib \
	-Wl,-compatibility_version,1 -Wl,-flat_namespace \
	-Wl,-undefined,warning -Wl,-current_version,1173.0.3 \
	-Wl,-install_name,/usr/lib/system/libdispatch.dylib \
	-Wl,-dead_strip -umbrella System \
	-Wl,-alias_list,${.CURDIR}/xcodeconfig/libdispatch.aliases \
	-Wl,-interposable_list,${.CURDIR}/xcodeconfig/libdispatch.interposable \
	-Wl,-order_file,${.CURDIR}/xcodeconfig/libdispatch.order \
	-mmacos-version-min=${MACOS_VERSION_MIN}

all: lib${LIB}.dylib

${.OBJDIR}/protocolServer.h ${.OBJDIR}/protocol.h \
	${.OBJDIR}/libdispatch_internal_protocolServer.c \
	${.OBJDIR}/libdispatch_internal_protocolUser.c: ${.CURDIR}/src/protocol.defs
	${MIG} ${MIG_FLAGS} -header protocol.h \
	  -sheader protocolServer.h ${.ALLSRC}

${.CURDIR}/firehoseServer.h \
	${.CURDIR}/firehose.h \
	${.CURDIR}/firehoseServer.c \
	${.CURDIR}/firehoseUser.c: ${.CURDIR}/src/firehose/firehose.defs
	${MIG} ${MIG_FLAGS} -header firehose.h \
	  -sheader firehoseServer.h ${.ALLSRC}

${.OBJDIR}/firehose_replyServer.h ${.OBJDIR}/firehose_reply.h \
	${.OBJDIR}/firehoseReplyServer.c \
	${.OBJDIR}/firehoseReplyUser.c: ${.CURDIR}/src/firehose/firehose_reply.defs
	${MIG} ${MIG_FLAGS} -header firehose_reply.h \
		-sheader firehose_replyServer.h ${.ALLSRC}

lib${LIB}.dylib: ${.OBJDIR}/lib${LIB}.dylib

${.OBJDIR}/BlocksRuntime:
	mkdir -p ${.TARGET}
	cp -f ${.CURDIR}/../libsystem_blocks/Block_private.h ${.TARGET}/

migs: ${.OBJDIR}/protocolServer.h ${.CURDIR}/firehoseServer.h \
	${.OBJDIR}/firehose_replyServer.h

${.OBJDIR}/lib${LIB}.dylib: ${.OBJDIR}/BlocksRuntime migs ${LOBJS}
	${CC} -fuse-ld=${LD} -shared -dylib -o ${.TARGET} ${LOBJS} ${LDFLAGS}
	cp -f ${.TARGET} ${RAVYN_SDKROOT}/usr/lib/system/
	cp -f ${.TARGET} ${SYSROOT_DIR}/usr/lib/system/

.include <bsd.lib.mk>
