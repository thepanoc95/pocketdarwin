diff --git a/lk2nd/device/menu/menu.c b/lk2nd/device/menu/menu.c
index 28ab377e7..fa9b925bd 100644
--- a/lk2nd/device/menu/menu.c
+++ b/lk2nd/device/menu/menu.c
@@ -12,7 +12,12 @@
 #include <string.h>
 #include <sys/types.h>
 
+#include <lib/bio.h>
+#include <lib/fs.h>
+
+#include <lk2nd/boot.h>
 #include <lk2nd/device/keys.h>
+#include <lk2nd/hw/bdev.h>
 #include <lk2nd/util/minmax.h>
 #include <lk2nd/version.h>
 
@@ -134,6 +139,168 @@ static void opt_bootloader(void) { reboot_device(FASTBOOT_MODE); }
 static void opt_edl(void)        { reboot_device(EMERGENCY_DLOAD); }
 static void opt_shutdown(void)   { shutdown_device(); }
 
+static void opt_boot_file(void)
+{
+	struct fbcon_config *fb = fbcon_display();
+	struct bdev_struct *bdevs;
+	char mountpoint[16];
+	dirhandle *dir;
+	struct dirent ent;
+	bdev_t *bdev;
+	int ret;
+
+#define MAX_BOOT_FILES 32
+	char mp_list[MAX_BOOT_FILES][16];
+	char file_list[MAX_BOOT_FILES][FS_MAX_FILE_LEN];
+	char disp_list[MAX_BOOT_FILES][FS_MAX_FILE_LEN];
+	int num_files = 0;
+	int y, y_menu, incr;
+
+	static bool bdev_init_done = false;
+
+	incr = FONT_HEIGHT * scale_factor;
+
+	fbcon_clear();
+	fbcon_puts("Scanning partitions...", SILVER, fb->height / 2, true);
+	fbcon_flush();
+
+	if (!bdev_init_done) {
+		lk2nd_bdev_init();
+		bdev_init_done = true;
+	}
+
+	bdevs = bio_get_bdevs();
+
+	list_for_every_entry(&bdevs->list, bdev, bdev_t, node) {
+		if (!bdev->is_leaf)
+			continue;
+
+		if (bdev->size < (16 * 1024 * 1024) &&
+		    !(bdev->label && !strncmp(bdev->label, "boot", 4)))
+			continue;
+
+		snprintf(mountpoint, sizeof(mountpoint), "/%s", bdev->name);
+		ret = fs_mount(mountpoint, "ext2", bdev->name);
+		if (ret < 0)
+			ret = fs_mount(mountpoint, "fat", bdev->name);
+		if (ret < 0)
+			continue;
+
+		{
+			char dirpath[FS_MAX_PATH_LEN];
+
+			snprintf(dirpath, sizeof(dirpath), "%s/lk2nd", mountpoint);
+			ret = fs_open_dir(dirpath, &dir);
+			if (ret < 0)
+				continue;
+
+			while (fs_read_dir(dir, &ent) == 0 && num_files < MAX_BOOT_FILES) {
+				char *at;
+
+				if (!strcmp(ent.name, ".") || !strcmp(ent.name, ".."))
+					continue;
+
+				strlcpy(mp_list[num_files], mountpoint, sizeof(mp_list[num_files]));
+				strlcpy(file_list[num_files], ent.name, sizeof(file_list[num_files]));
+
+				at = strchr(ent.name, '@');
+				if (at) {
+					size_t prefix_len = at - ent.name;
+					memcpy(disp_list[num_files], ent.name, prefix_len);
+					disp_list[num_files][prefix_len] = '\0';
+				} else {
+					strlcpy(disp_list[num_files], ent.name, sizeof(disp_list[num_files]));
+				}
+
+				num_files++;
+			}
+
+			fs_close_dir(dir);
+		}
+		break;
+	}
+
+	if (num_files == 0) {
+		fbcon_clear();
+		fbcon_puts("No binaries found in /lk2nd/", RED, fb->height / 2 - incr, true);
+		fbcon_puts("Press any key to return", SILVER, fb->height / 2, true);
+		fbcon_flush();
+		wait_key();
+		return;
+	}
+
+	y = incr * 2;
+	fbcon_clear();
+	fbcon_printf(WHITE, y, true, "Select binary to boot:");
+	y += incr * 2;
+	y_menu = y;
+	y += incr * (num_files + 2);
+
+	fbcon_printf(SILVER, y, true, "Volume keys to navigate,");
+	y += incr;
+	fbcon_printf(SILVER, y, true, "Power to select.");
+
+	{
+		int sel = 0;
+
+		while (true) {
+			int i;
+
+			y = y_menu;
+			fbcon_clear_msg(y / FONT_HEIGHT,
+					y / FONT_HEIGHT + num_files * scale_factor);
+
+			for (i = 0; i < num_files; i++) {
+				unsigned color = i == sel ? WHITE : SILVER;
+				char indicator = i == sel ? '>' : ' ';
+
+				fbcon_printf(color, y, true,
+					     "%c %s %c",
+					     indicator, disp_list[i], indicator);
+				y += incr;
+			}
+
+			fbcon_flush();
+
+			switch (wait_key()) {
+			case KEY_POWER:
+				if (sel >= 0 && sel < num_files) {
+					char relpath[FS_MAX_PATH_LEN];
+
+					snprintf(relpath, sizeof(relpath), "lk2nd/%s",
+						 file_list[sel]);
+					fbcon_clear();
+					fbcon_puts("Booting...", WHITE,
+						   fb->height / 2, true);
+					fbcon_flush();
+					lk2nd_boot_file(mp_list[sel], relpath);
+					fbcon_clear();
+					fbcon_puts("Error: failed to boot",
+						   RED, fb->height / 2 - incr, true);
+					fbcon_puts("Press any key",
+						   SILVER, fb->height / 2, true);
+					fbcon_flush();
+					wait_key();
+				}
+				break;
+			case KEY_VOLUMEUP:
+				if (sel == 0)
+					sel = num_files - 1;
+				else
+					sel--;
+				break;
+			case KEY_VOLUMEDOWN:
+				sel++;
+				if (sel >= num_files)
+					sel = 0;
+				break;
+			default:
+				break;
+			}
+		}
+	}
+}
+
 static struct {
 	char *name;
 	unsigned color;
@@ -144,6 +311,7 @@ static struct {
 	{ " Recovery ", ORANGE, opt_recovery },
 	{ "Bootloader", ORANGE, opt_bootloader },
 	{ "    EDL   ", RED,    opt_edl },
+	{ "Boot file", YELLOW, opt_boot_file },
 	{ " Shutdown ", RED,    opt_shutdown },
 };
 
