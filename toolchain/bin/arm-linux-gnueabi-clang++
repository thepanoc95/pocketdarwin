#!/bin/bash
# XNU Clang++ wrapper for ARM (AArch32) cross-compilation on Linux.
CLANG=${CXX:-/usr/bin/clang++}
ROOT="$(dirname "$(dirname "$0")")"

exec "$CLANG" \
    --target=arm-linux-gnueabi \
    -fdeclspec \
    -D__arm__ \
    -I"$ROOT/Kernel" \
    -I"$ROOT/Kernel/osfmk" \
    -I"$ROOT/Kernel/bsd" \
    -I"$ROOT/Kernel/bsd/arm" \
    -I"$ROOT/Kernel/osfmk/arm" \
    "$@"