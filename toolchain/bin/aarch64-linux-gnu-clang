#!/bin/bash
# XNU Clang wrapper for ARM64 (AArch64) cross-compilation on Linux.
CLANG=/usr/bin/clang
ROOT="$(dirname "$(dirname "$0")")"

exec "$CLANG" \
    --target=aarch64-linux-gnu \
    -D__arm64__ \
    -D__LP64__ \
    -D__ARM64_ARCH__=8 \
    -I"$ROOT/Kernel" \
    -I"$ROOT/Kernel/osfmk" \
    -I"$ROOT/Kernel/bsd" \
    -I"$ROOT/Kernel/bsd/arm" \
    -I"$ROOT/Kernel/osfmk/arm" \
    -I"$ROOT/Kernel/osfmk/arm64" \
    -I"$ROOT/Kernel/bsd/arm64" \
    "$@"