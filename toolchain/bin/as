#!/bin/bash
# Wrapper: forward as to arm-linux-gnueabi-as for ARM cross-compilation.
# Pre-process assembly to fix ; separator after .code 16 directive.
DIR="$(dirname "$0")"
INPUT_FILE=""
OUTPUT_FILE=""
OTHER_ARGS=()

# Parse args to find input/output files
while [ $# -gt 0 ]; do
    case "$1" in
        -o) OUTPUT_FILE="$2"; shift 2 ;;
        *.s|*.S|*.sx) INPUT_FILE="$1"; shift ;;
        *) OTHER_ARGS+=("$1"); shift ;;
    esac
done

if [ -n "$INPUT_FILE" ] && [ -n "$OUTPUT_FILE" ]; then
    # Check if pre-processing is needed
    if grep -q '\.code\s*16\s*;\|\.thumb\s*;\|\.thumb_func\s\+' "$INPUT_FILE" 2>/dev/null; then
        TMPFILE=$(mktemp --tmpdir asm_wrapper.XXXXXX.s)
        # Add .syntax unified for GAS compatibility with Thumb UAL
        echo '.syntax unified' > "$TMPFILE"
        sed -e 's/\.code\s*16\s*;/.code 16\n/g' \
            -e 's/\.code\s*32\s*;/.code 32\n/g' \
            -e 's/\.thumb\s*;/.thumb\n/g' \
            -e 's/\.thumb_func\s\+\([a-zA-Z_][a-zA-Z0-9_]*\)\s*;/.thumb_func\n\t.globl \1\n/g' \
            "$INPUT_FILE" >> "$TMPFILE"
        "$DIR/arm-linux-gnueabi-as" "${OTHER_ARGS[@]}" -o "$OUTPUT_FILE" "$TMPFILE"
        RC=$?
        rm -f "$TMPFILE"
        exit $RC
    else
        exec "$DIR/arm-linux-gnueabi-as" "$@"
    fi
else
    exec "$DIR/arm-linux-gnueabi-as" "$@"
fi
